# Backend Production Environment Variables
# Copy this to .env for Render deployment or use Render's environment variables

# Application
PROJECT_NAME=AI Knowledge Assistant
APP_ENV=production
API_V1_PREFIX=/api/v1

# Database - Render will provide DATABASE_URL automatically
# DATABASE_URL=postgresql://user:password@host:port/database

# JWT Authentication - Generate a strong secret key
JWT_SECRET_KEY=change-me-to-a-strong-random-secret-key-min-32-chars
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# File Upload
UPLOAD_ROOT_DIR=./storage/uploads
MAX_UPLOAD_SIZE_BYTES=10485760

# Vector Database
CHROMA_PERSIST_DIRECTORY=./storage/chroma
CHROMA_COLLECTION_NAME=knowledge_chunks

# Embeddings
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# RAG Pipeline
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=4

# LLM Configuration
LLM_PROVIDER=ollama
LLM_MODEL_NAME=llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3
OLLAMA_KEEP_ALIVE=5m

# CORS - Replace with your Vercel frontend URL
BACKEND_CORS_ORIGINS=["https://your-frontend.vercel.app","https://your-custom-domain.com"]
